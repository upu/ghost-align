{
  "permissions": {
    "allow": [
      "Bash(npm test*)",
      "Bash(npm run compile*)",
      "Bash(npm run check:package*)",
      "Bash(git pull *)",
      "Bash(git fetch *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git ls-files *)",
      "Bash(git check-ignore *)",
      "Bash(gh label list*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npm run compile",
            "statusMessage": "Compiling TypeScript..."
          }
        ]
      }
    ]
  }
}
