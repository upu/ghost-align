{
  "permissions": {
    "allow": [
      "Bash(npm test*)",
      "Bash(npm run compile*)",
      "Bash(npm run check:package*)",
      "Bash(git pull *)",
      "Bash(git fetch *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git ls-files *)",
      "Bash(git check-ignore *)",
      "Bash(gh label list*)",
      "Bash(gh run watch *)",
      "Bash(git worktree remove .claude/worktrees/*)",
      "Bash(git worktree prune*)",
      "Bash(git branch -D worktree-agent-*)",
      "Bash(rm -rf .claude/worktrees/*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/compile-if-ts.js",
            "statusMessage": "Compiling TypeScript..."
          }
        ]
      }
    ]
  }
}
